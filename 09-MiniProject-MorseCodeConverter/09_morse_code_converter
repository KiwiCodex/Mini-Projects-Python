# Sound for fun
def play_morse(morse: str):
    unit = 150
    freq = 800

    print("Just heard it!")

    for char in morse:
        if char == '.':
            winsound.Beep(freq, unit)
            time.sleep(unit/1000)
        elif char == '-':
            winsound.Beep(freq, unit*3)
            time.sleep(unit/1000)
        elif char == ' ' or char == '/':
            time.sleep((unit * 3)/1000)


# 3. Create a main entry point
def main() -> None:
    # 4. Get that sexy user input
    user_input: str = input('Enter text: ')

    if user_input:

        encoded: str = convert_to_morse(user_input)
        print(encoded)
        play_morse(encoded)
        
        decoded: str = decode_morse(encoded)
        print(f"Original Text: {decoded}")

        print("\nSound Transmission finished!")


# Run the script
if __name__ == "__main__":
    main()
